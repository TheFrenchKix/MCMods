{
  "schemaVersion": 1,
  "name": "lfm Client",
  "id": "lfm-client",
  "version": "${version}",
  "description": "Based utility mod.",
  "authors": [
    "MineGame159",
    "squidoodly",
    "seasnail"
  ],
  "contact": {
    "homepage": "https://lfmclient.com",
    "issues": "https://github.com/lfmDevelopment/lfm-client/issues",
    "sources": "https://github.com/lfmDevelopment/lfm-client",
    "discord": "https://lfmclient.com/discord"
  },
  "license": "GPL-3.0",
  "icon": "assets/lfm-client/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "lfmdevelopment.lfmclient.lfmClient"
    ],
    "modmenu": [
      "lfmdevelopment.lfmclient.modintegration.ModMenuIntegration"
    ]
  },
  "mixins": [
    "meteor-client.mixins.json",
    "meteor-client-baritone.mixins.json",
    "meteor-client-indigo.mixins.json",
    "meteor-client-sodium.mixins.json",
    "meteor-client-lithium.mixins.json",
    "meteor-client-viafabricplus.mixins.json"
  ],
  "accessWidener": "meteor-client.accesswidener",
  "custom": {
    "lfm-client:build_number": "${build_number}",
    "lfm-client:color": "145,61,226",
    "lfm-client:commit": "${commit}",
    "modmenu": {
      "links": {
        "modmenu.discord": "https://lfmclient.com/discord"
      }
    },
    "badoptimizations:cache_hooks": {
      "lightmap": "lfmdevelopment.lfmclient.modintegration.BadOptimizationsHook"
    }
  },
  "depends": {
    "java": ">=21",
    "minecraft": ["${minecraft_version}"],
    "fabricloader": ">=${loader_version}"
  },
  "breaks": {
    "optifabric": "*",
    "feather": "*",
    "origins": "*",
    "sodium": "<0.7.0",
    "morechathistory": "*",
    "lithium": "<0.21.3"
  }
}
